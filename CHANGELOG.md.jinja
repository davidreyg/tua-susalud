{% set type_labels = {
    "feat": "🚀 Nuevas funcionalidades",
    "fix": "🐛 Correcciones de errores",
    "refactor": "♻️ Refactorización",
    "perf": "⚡ Mejoras de rendimiento",
    "docs": "📝 Documentación",
    "style": "🎨 Estilo",
    "test": "✅ Pruebas",
    "build": "🏗️ Construcción",
    "ci": "👷 Integración continua",
    "chore": "🔧 Tareas varias",
    "breaking change": "💥 Breaking Changes",
} %}
{% macro commit_link(sha) %}
{%- if repo_url is defined and repo_url -%}
[`{{ sha[:7] }}`]({{ repo_url }}/commit/{{ sha }})
{%- else -%}
`{{ sha[:7] }}`
{%- endif -%}
{% endmacro %}
{% if not incremental -%}
# CHANGELOG{% endif %}
{% for entry in tree %}
{% if entry.version %}

## [{{ entry.version }}]{% if entry.date %} - {{ entry.date }}{% endif %}

{% endif %}
{% if entry.breaking_changes %}

> [!CAUTION]
> Se incluyen cambios rompientes.

{% endif %}
{% for change_type, changes in entry.changes.items() %}
{% set type_label = type_labels.get(change_type.lower(), change_type | capitalize) %}
{% if change_type.lower() == "breaking change" %}
### 💥 Breaking Changes

{% for change in changes %}
{% if change.scope %}
- **{{ change.scope }}:** {{ change.message }} ({{ commit_link(change.sha1) }})
{% else %}
- {{ change.message }} ({{ commit_link(change.sha1) }})
{% endif %}
{% endfor %}
{% else %}
### {{ type_label }}

{% set scopes = changes | selectattr("scope") | map(attribute="scope") | unique | list %}
{% if scopes %}
{% for scope in scopes %}
**`{{ scope }}`**
{% for change in changes if change.scope == scope %}
- {{ change.message }} ({{ commit_link(change.sha1) }})
{% endfor %}
{% endfor %}
{% set unscope = changes | rejectattr("scope") | list %}
{% if unscope %}
{% for change in unscope %}
- {{ change.message }} ({{ commit_link(change.sha1) }})
{% endfor %}
{% endif %}
{% else %}
{% for change in changes %}
- {{ change.message }} ({{ commit_link(change.sha1) }})
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}
